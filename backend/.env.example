# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# ── AWS Bedrock ───────────────────────────────────────────────────────────────
# Credentials: use env vars, ~/.aws/credentials, or an IAM role (EC2/ECS).
# AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY are only needed when not using
# an IAM role or a credentials file.
#
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
BEDROCK_MODEL=us.anthropic.claude-3-5-sonnet-20241022-v2:0

# Newer models require a cross-region inference profile ID (us. prefix).
# For extended thinking support, use one of:
#   us.anthropic.claude-3-7-sonnet-20250219-v1:0
#   us.anthropic.claude-opus-4-5-20251101-v1:0

# Set to 0 to disable extended thinking (use for models that don't support it)
# BEDROCK_THINKING_BUDGET=8000
